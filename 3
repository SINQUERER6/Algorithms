class HashOper:
    def __init__(self,size:int):
        self.size:int =size
        self.table:list[list[tuple[str,int]]]=[[] for _ in range(size)]
    def calcu(self,key: str) -> int:
        result:int=1
        for char in key:
            result*=ord(char)-ord("a")+1
            result %= self.size
        return result
    def put(self,key:str,value:int)->None:
        result:int=self.calcu(key)
        bucket:list[tuple[str,int]]=self.table[result]
        for i,(old_key,old_value) in enumerate(bucket):
            if key == old_key:
                bucket[i]=(key,value)
                return
        else:
                bucket.append((key,value))
    def get(self,key:str) -> int | None:
        result:int=self.calcu(key)
        bucket:list[tuple[str,int]]=self.table[result]
        for bucket_key,bucket_value in bucket:
            if key == bucket_key:
                return bucket_value
        return None
    def Del(self,key:str)->None:
        result:int=self.calcu(key)
        bucket:list[tuple[str,int]]=self.table[result]
        for index,(bucket_key,bucket_value) in enumerate(bucket):
            if key == bucket_key:
                del bucket[index]
        return None
    def __str__(self)->str:
        items={}
        for bucket in self.table:
            for key,value in bucket:
                items[key]=value
        return str(items)
        
